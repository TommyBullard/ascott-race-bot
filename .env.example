# Supabase project URL (e.g. https://your-project.supabase.co)
SUPABASE_URL=

# Supabase service-role key.
# SERVER-SIDE ONLY — this key bypasses Row Level Security (RLS).
# Use the SECRET key (sb_secret_... or a legacy eyJ... JWT), NOT a publishable
# (sb_publishable_...) key. Never expose it to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for the scheduled cron endpoint (/api/cron/recommendations).
# When set, the endpoint requires "Authorization: Bearer <CRON_SECRET>".
# Vercel Cron sends this header automatically.
CRON_SECRET=
