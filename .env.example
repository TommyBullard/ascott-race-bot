# ──────────────────────────────────────────────────────────────────────────
# Environment variables for Ascot Race Bot.
#
# This is a TEMPLATE. Copy it to `.env.local` (preferred for local dev) and fill
# in real values to the right of each `=` (no quotes, no spaces around the `=`).
# The scripts load `.env.local` first, then `.env`.
#
#   - `.env.local` (and any `.env*.local`) is GIT-IGNORED — see .gitignore. Keep
#     your real secrets there; NEVER commit them. This `.env.example` is the only
#     env file that is tracked, and it must stay empty of real values.
#   - Every variable is read from the environment and validated LAZILY (at
#     request time, on first use), so a production build (`next build`) and the
#     dev server start even when values are blank — a route that needs a missing
#     value fails at request time with a clear error (see notes below).
#   - Check which variables are set with `npm run check:env` (prints names +
#     present/missing only — never values).
# ──────────────────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://your-project.supabase.co).
# Required by everything that touches the database.
SUPABASE_URL=

# Supabase service-role key.
# SERVER-SIDE ONLY — this key bypasses Row Level Security (RLS) and must NEVER be
# exposed to the browser or committed. It is used only by server-side code
# (route handlers, scripts). Use the SECRET key (sb_secret_... or a legacy eyJ...
# JWT), NOT a publishable (sb_publishable_...) key.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret protecting the cron + manual operational endpoints (the Vercel
# Cron routes under /api/cron/* and the manual, DB-mutating POST /api/run-model).
# YOU GENERATE THIS YOURSELF — it is NOT issued by any external provider. Use any
# long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# When set, those endpoints require "Authorization: Bearer <CRON_SECRET>" (Vercel
# Cron sends this header automatically). When unset, they fall back to open
# local/dev behaviour, so set it in every deployed environment.
CRON_SECRET=

# The Racing API credentials (HTTP Basic), used by the racecards / results /
# tipster-discovery pipelines. Sign up at https://www.theracingapi.com (a paid,
# ToS-compliant plan that includes /v1/racecards/standard and /v1/results).
# IF THESE ARE MISSING, /api/cron/racecards (and results / tipster-discovery)
# WILL FAIL at request time with "Missing environment variable: RACING_API_USER".
RACING_API_USER=
RACING_API_KEY=

# OPTIONAL: which racecards endpoint tier to use — `standard` (default) or
# `basic`. `standard` uses /racecards/standard (richer, includes bundled odds;
# needs the Standard plan) and, if your plan returns "Standard Plan required",
# automatically falls back to the basic /racecards/free endpoint. Set `basic` to
# skip the standard attempt entirely. Basic cards carry NO odds, which does not
# affect racecard ingestion (odds come from the Betfair odds pipeline). Unset =
# standard.
RACING_API_RACECARDS_TIER=

# Betfair Exchange API credentials (cert-based non-interactive login). Required
# ONLY by the live odds pipeline (/api/cron/odds). Leave blank if you are not
# using live odds (e.g. local testing with the demo seed).
# IF BETFAIR SETUP IS INCOMPLETE, /api/cron/odds WILL FAIL — every other pipeline
# (racecards, results, model runs, the tipster importer, the dashboard) works
# without Betfair.
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# Betfair client certificate + private key, in PEM format. Treat BOTH as secrets
# — never log, print, commit, or store them inside the repo.
#   - CERT SETUP IS A MANUAL STEP: you generate a certificate, upload the PUBLIC
#     certificate (the .crt) to your Betfair account (Betfair > My Account >
#     Automated Betting Program Access), and use the matching cert + private key
#     here. See Betfair's non-interactive (bot) login docs.
#   - The PRIVATE KEY (BETFAIR_KEY_PEM) MUST NEVER BE COMMITTED. Keep it in your
#     git-ignored `.env.local` only.
# NEWLINE-SAFE FORMATTING: some deployment platforms (e.g. Vercel) do not
# preserve real newlines in env values. You may store these with literal "\n"
# sequences; the app converts them back to real newlines at request time.
BETFAIR_CERT_PEM=
BETFAIR_KEY_PEM=

# OPTIONAL: set to 1 to emit verbose model trace logs (development only).
# Unset/anything-else disables tracing. Not a secret.
DEBUG_MODEL=
