# ──────────────────────────────────────────────────────────────────────────
# Environment variables for Ascot Race Bot.
#
# Copy this file to `.env` and fill in real values. Every variable is read from
# the environment and validated LAZILY (at request time, on first use), so a
# production build (`next build`) does NOT fail just because runtime secrets are
# absent. Never commit your real `.env`.
# ──────────────────────────────────────────────────────────────────────────

# Supabase project URL (e.g. https://your-project.supabase.co)
SUPABASE_URL=

# Supabase service-role key.
# SERVER-SIDE ONLY — this key bypasses Row Level Security (RLS) and must NEVER
# be exposed to the browser or committed. Use the SECRET key (sb_secret_... or a
# legacy eyJ... JWT), NOT a publishable (sb_publishable_...) key.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret protecting the cron + manual operational endpoints (the Vercel
# Cron routes under /api/cron/* and the manual, DB-mutating POST /api/run-model).
# When set, those endpoints require "Authorization: Bearer <CRON_SECRET>"
# (Vercel Cron sends this header automatically). When unset, they fall back to
# open local/dev behaviour, so set it in every deployed environment.
CRON_SECRET=

# The Racing API credentials (HTTP Basic), used by the racecards / results /
# tipster-discovery pipelines.
RACING_API_USER=
RACING_API_KEY=

# Betfair Exchange API credentials (cert-based non-interactive login).
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# Betfair client certificate + private key, in PEM format. Treat both as
# secrets — never log or expose them.
# NEWLINE-SAFE FORMATTING: some deployment platforms (e.g. Vercel) do not
# preserve real newlines in env values. You may store these with literal "\n"
# sequences; the app converts them back to real newlines at request time.
BETFAIR_CERT_PEM=
BETFAIR_KEY_PEM=
